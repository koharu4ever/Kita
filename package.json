{
  "name": "kita",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "workspace:check-user": "node scripts/assert-dev-workspace-user.mjs --check-next",
    "dev": "node scripts/assert-dev-workspace-user.mjs --check-next --mode=dev && next dev",
    "dev:services": "node scripts/assert-dev-workspace-user.mjs && docker compose -f compose.yaml -f compose.dev.yaml up -d postgres",
    "dev:services:stop": "node scripts/assert-dev-workspace-user.mjs && docker compose -f compose.yaml -f compose.dev.yaml stop postgres",
    "build": "node scripts/assert-dev-workspace-user.mjs --check-next --mode=build && next build",
    "start": "node scripts/assert-dev-workspace-user.mjs --check-next && next start",
    "lint": "node scripts/assert-dev-workspace-user.mjs && eslint .",
    "lint:fix": "node scripts/assert-dev-workspace-user.mjs && eslint . --fix",
    "format": "node scripts/assert-dev-workspace-user.mjs && prettier . --write",
    "format:check": "node scripts/assert-dev-workspace-user.mjs && prettier . --check",
    "payload:importmap": "node scripts/assert-dev-workspace-user.mjs && payload generate:importmap --use-swc",
    "payload:migrate": "node scripts/assert-dev-workspace-user.mjs && payload migrate --use-swc",
    "payload:migrate:create": "node scripts/assert-dev-workspace-user.mjs && payload migrate:create --use-swc",
    "payload:migrate:status": "node scripts/assert-dev-workspace-user.mjs && payload migrate:status --use-swc",
    "payload:types": "node scripts/assert-dev-workspace-user.mjs && payload generate:types --use-swc",
    "check": "node scripts/assert-dev-workspace-user.mjs --check-next && pnpm format:check && pnpm lint && pnpm typecheck",
    "typecheck": "node scripts/assert-dev-workspace-user.mjs --check-next && tsc --noEmit",
    "seed:games": "node scripts/assert-dev-workspace-user.mjs && curl -X POST http://localhost:3000/api/dev/seed-games",
    "seed:tools": "node scripts/assert-dev-workspace-user.mjs && curl -X POST http://localhost:3000/api/dev/seed-tools"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "^3.85.1",
    "@payloadcms/next": "^3.85.1",
    "@payloadcms/richtext-lexical": "3.85.1",
    "@t3-oss/env-nextjs": "^0.13.11",
    "next": "^16.2.7",
    "payload": "^3.85.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.35.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.41",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^22.19.20",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.7",
    "eslint-plugin-unused-imports": "^4.4.1",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3"
  }
}
