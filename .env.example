# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Payload CMS.
# Server-only. Do not prefix with NEXT_PUBLIC_.
PAYLOAD_SECRET=replace-with-a-long-random-secret-value

# Local-only seed switch.
# Keep this false unless you are intentionally running a development seed.
ENABLE_DEV_SEED=false

# Local PostgreSQL service. DATABASE_URI must use the same user, password,
# and database. These development values are intentionally different from
# production secrets managed by Coolify.
POSTGRES_DB=kita
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URI=postgres://postgres:postgres@localhost:5432/kita

# If you use docker-outside-of-docker or run Postgres from Windows PowerShell,
# your local .env may need:
# DATABASE_URI=postgres://postgres:postgres@host.docker.internal:5432/kita

# In the Coolify/production Compose network, the web service uses:
# DATABASE_URI=postgres://postgres:postgres@postgres:5432/kita

# Optional escape hatch for special CI/build situations.
# Leave this unset during normal local development.
# SKIP_ENV_VALIDATION=true

# Optional production PostgreSQL backup sidecar.
# Local development stays disabled and does not need R2 credentials.
POSTGRES_BACKUP_ENABLED=false
POSTGRES_BACKUP_INTERVAL_SECONDS=86400
POSTGRES_BACKUP_RETRY_SECONDS=3600
POSTGRES_BACKUP_WAIT_SECONDS=120
POSTGRES_BACKUP_R2_ENDPOINT=
POSTGRES_BACKUP_R2_BUCKET=kita-postgres-backups
POSTGRES_BACKUP_R2_ACCESS_KEY_ID=
POSTGRES_BACKUP_R2_SECRET_ACCESS_KEY=
